# Apple iCloud credentials
ICLOUD_USERNAME=your.apple.id@example.com
ICLOUD_PASSWORD=your-apple-id-password

# Telegram bot (create via BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321

# Windows PC SMB share
SMB_HOST=192.168.1.100
SMB_SHARE=Storage
SMB_USERNAME=your-windows-username
SMB_PASSWORD=your-windows-password
SMB_MOUNT_PATH=/mnt/storage

# Scoring weights (must sum to 100)
WEIGHT_AGE=35
WEIGHT_SIZE=20
WEIGHT_SOURCE=30
WEIGHT_DUPLICATE=15

# Score thresholds (0-100)
AUTO_OFFLOAD_THRESHOLD=65
REVIEW_THRESHOLD=40
# Max assets the review bucket surfaces per run (prioritised by reclaimable
# size); the overflow is deferred to later runs. 0 = unlimited.
REVIEW_MAX_ITEMS=50
FAVORITE_SCORE_PENALTY=60
LARGE_FILE_MB=50

# Scanner behaviour
# Dry run: log actions without downloading or deleting anything
DRY_RUN=true
# Minimum age in days before an asset is eligible for offload
MIN_AGE_DAYS=180
# Cap how many assets a single live offload run moves (0 = unlimited). Useful to
# keep an initial real test to a small, safe handful.
OFFLOAD_MAX_ITEMS=0
# Storage tier recorded against offloaded assets, for the index's local-vs-network
# summary: "local" (a directly attached drive) or "network" (the Pi/NAS share).
STORAGE_TIER=network
# Optional capture-date window (inclusive, YYYY-MM-DD) to limit a scan — handy
# for testing on a small slice. Leave blank for the whole library.
SCAN_SINCE=
SCAN_UNTIL=
# Album membership index cache TTL in hours. Avoids rebuilding the album index
# (~19 min) on every run by persisting a JSON cache next to INDEX_DB_PATH.
# Set to 0 to always rebuild.
ALBUM_CACHE_MAX_AGE_HOURS=168
# Index-only fast mode: skip the live iCloud scan and read assets straight from
# the SQLite index (seconds vs ~10 min). Requires a prior full scan to have
# populated the index; honours SCAN_SINCE/SCAN_UNTIL. Won't see assets added
# since that scan. Leave false for normal (live-scan) runs.
SCAN_FROM_INDEX=false
# Weekly scan day and time (0=Monday, 6=Sunday)
SCAN_DAY_OF_WEEK=sunday
SCAN_TIME=02:00

# Searchable asset index (SQLite). In Docker this lives on the asset-index
# volume mounted at /app/data; the default path resolves there.
INDEX_DB_PATH=data/asset_index.db
